<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users List</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <div class="container">
        <h1>Users List</h1>
        <ul>
            <% usersList.forEach(user => { %>
                <li><strong>Name:</strong> <%= user.name %>, <strong>Age:</strong> <%= user.age %>, <strong>Email:</strong> <%= user.email %></li>
            <% }); %>
        </ul>
    </div>
</body>
</html>
